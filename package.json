{
  "name": "equalify-iris",
  "version": "0.1.0",
  "description": "Image-to-Accessible-HTML parsing service (Equalify Iris)",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node --use-system-ca --env-file-if-exists=.env --experimental-sqlite src/index.ts",
    "dev": "node --use-system-ca --env-file-if-exists=.env --experimental-sqlite --watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.682.0",
    "@octokit/rest": "^21.0.2",
    "axe-core": "^4.10.2",
    "express": "^4.21.1",
    "jsdom": "^25.0.1",
    "multer": "^2.1.1",
    "ulid": "^2.3.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsdom": "^21.1.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
}
